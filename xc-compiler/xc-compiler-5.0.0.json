{
  "id": "compilers/arm/xc-compiler",
  "version": "5.0.0",
  "description": "XC Compiler toolchain for C/C++ and assembly development on Arm Cortex-class MCUs.",
  "summary": "XC Compiler for Arm CPUs",
  "contacts": {
    "xc-compiler-team": {
      "email": "ashish.mahanth@microchip.com",
      "role": "originator"
    }
  },
  "demands": {
    "windows": {
      "install": {
        "untar": "https://artifacts.microchip.com/artifactory/xc-generic-release-candidate/toolchain-images/xc32_windows.tar.xz",
        "sha256": "106b149f6ff079dc401276b6d82cf8d29676d194b093901bc760a88739429eee",
        "strip": 0
      },
      "exports": {
        "paths": {
          "PATH": "bin"
        },
        "tools": {
          "XC_COMPILER_5_0_0": "./bin"
        }
      }
    },
    "linux and x64": {
      "install": {
        "untar": "https://artifacts.microchip.com/artifactory/xc-generic-release-candidate/toolchain-images/xc32_linux.tar.xz",
        "sha256": "973d51d51f42fba2a46f598e011bdaad226c098bf43a2c79591593982f6ab117",
        "strip": 0
      }
    },
    "osx": {
      "install": {
        "untar": "https://artifacts.example.com/xc-compiler/5.0.0/xc-c",
        "sha256": "REPLACE_WITH_REAL_SHA256",
        "strip": 1
      }
    },
    "not windows": {
      "exports": {
        "paths": {
          "PATH": "bin"
        },
        "tools": {
          "XC_COMPILER_5_0_0": "./bin"
        }
      }
    }
  }
}
